新闻

task_name: "Sina Finance 7x24"

source:
  entry_url: "https://finance.sina.com.cn/7x24/"
  timezone: "Asia/Shanghai"
  language: "zh-CN"

time_window:
  lookback: "180min"
  reference_time: "run_time"
  inclusion_rule: >
    Use the timestamp shown on the Sina 7x24 page (Asia/Shanghai).
    Include an item if item_time >= (run_time_in_AsiaShanghai - 180 min).

fetch_scope:
  target: "7x24 feed list items on the entry page"
  scrolling_or_pagination:
    required: true
    stop_condition: "Stop when the oldest visible item_time is older than the 180min window AND no more items can be loaded."
  item_fields_to_extract:
    - "item_time (HH:MM or full timestamp as shown)"
    - "title"
    - "link (if available)"
    - "brief content/snippet (if shown)"
  detail_page_policy:
    open_detail_if_needed: true
    only_when: "If the entry page does not provide enough info to summarize accurately."
    must_not_assume: true

filtering:
  goal: "International + Mainland China finance & macroeconomics news"
  include_if_any:
    # 中国大陆（宏观/金融）
    - "中国大陆宏观数据（GDP/CPI/PPI/PMI/社融/信贷/外贸/就业/房地产等）"
    - "中国货币政策/金融监管/财政政策（央行、金融监管总局、证监会、财政部、发改委等）"
    - "中国金融市场（A股、国债/地方债、利率、人民币汇率、黄金/原油/大宗商品与中国相关的交易与政策）"
    - "中国系统重要金融机构/银行/券商/保险/基金/资管行业的重大监管或风险事件"
    - "中国对外经济金融（外汇、跨境资本流动、贸易政策、对外投资、国际收支等）"

    # 国际（宏观/金融）
    - "非中国大陆的央行/货币政策（Fed/ECB/BoJ/BoE等）"
    - "全球主要市场（美/欧/日/港等）股债汇商品及重大市场事件"
    - "国际组织（IMF/World Bank/OECD/WTO等）相关经济金融信息"
    - "非中国大陆宏观数据（CPI、就业、GDP、PMI、贸易、油气库存等）"
    - "地缘政治/风险事件且对宏观或金融市场有明确影响（基于原文可支持）"

  exclude_if_all:
    - "与金融/经济无关的内容（娱乐、八卦、体育等）"

output_requirements:
  completeness: "Must include ALL items within the 180 min window that match the filter. Do not omit any matching item."
  no_fabrication: "Do not invent news, numbers, quotes, or causes not present in the source text."
  no_overcompression: "Do not merge different news items into one. Each item must be listed explicitly."
  determinism: "Be conservative and factual; avoid creative writing."

output_format:
  - section: "A) 执行信息"
    fields:
      - "抓取窗口（北京时间）：start_time ~ end_time"
      - "窗口内总条目数（未过滤）：N_total"
      - "过滤后条目数（金融/经济）：N_kept"
  - section: "B) 分类总览（按地区）"
    fields:
      - "中国大陆：条目数 N_cn；"
      - "国际：条目数 N_intl；"
  - section: "C) 逐条新闻（先中国大陆后国际；各组内按时间倒序）"
    per_item_template:
      - "时间（北京时间）"
      - "标题"
      - "可能影响（1–2 句；必须明确为推断；不得超出原文信息边界）"
      - "链接（如有）"
  - section: "E) 自评分（0–10）"
    rubric: "仅按 内容全面性 与 准确性 评分，并用 1 句说明扣分点/满分理由。"

generation_params:
  temperature: 0